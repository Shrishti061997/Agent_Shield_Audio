# --- service ---
PORT=8000

# --- pricing ---
# Flat USDC price per /v1/transcribe call (6 decimals → 0.01 = 10_000 base units)
PRICE_USDC=0.01

# --- x402 / payments ---
# Your receiving wallet (Base mainnet or Base Sepolia)
PAY_TO_ADDRESS=0x000000000000000000000000000000000000dEaD
# Network selector: base-sepolia (testnet) | base (mainnet)
NETWORK=base-sepolia
# Coinbase x402 facilitator endpoint
FACILITATOR_URL=https://x402.org/facilitator
# USDC contract on the chosen network
USDC_CONTRACT=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# --- models ---
# large-v3 (good translation) | large-v3-turbo (faster, transcription-only)
WHISPER_MODEL=large-v3
PROMPT_GUARD_MODEL=meta-llama/Prompt-Guard-86M
# 0.9 = high-confidence-only auto-flag from Prompt-Guard alone
INJECTION_SCORE_THRESHOLD=0.9
# Hard cap on accepted audio duration (seconds)
MAX_AUDIO_DURATION_SEC=1800

# --- caching ---
# Isolate model cache from system-wide HF_HOME (avoids permission issues)
HF_HOME=./.hf_cache

# --- youtube cookies (optional) ---
# If your host's IP is on YouTube's bot wall ("Sign in to confirm you're not a bot"),
# export cookies from a logged-in browser session to a Netscape cookies.txt and
# point this var at it. Leave unset on hosts where YouTube works without cookies.
# YT_COOKIES_FILE=/absolute/path/to/cookies.txt
